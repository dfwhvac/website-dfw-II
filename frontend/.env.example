# DFW HVAC — environment variables (copy to .env.local for local dev)
# On Vercel: set Production-only values in Project → Settings → Environment Variables.
# Do NOT add NEXT_PUBLIC_GA_ID to Preview or Development scopes.

# --- Sanity CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-write-token

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://dfwhvac.com

# --- Analytics (Production Vercel only) ---
# Tier 1: @next/third-parties <GoogleAnalytics gaId={...} />
NEXT_PUBLIC_GA_ID=G-5MX2NE7C73
# Optional; defaults to wjyapvd6n7 if unset on production
# NEXT_PUBLIC_CLARITY_ID=wjyapvd6n7

# Vercel injects VERCEL_ENV automatically (production | preview | development).
# Optional mirror for client-side checks:
# NEXT_PUBLIC_VERCEL_ENV=production

# --- Backend (legacy / optional) ---
NEXT_PUBLIC_API_URL=http://localhost:8001/api
